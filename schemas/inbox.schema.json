{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anvil.dev/schemas/inbox.schema.json",
  "title": "inbox",
  "type": "object",
  "required": ["type", "title", "created", "status"],
  "properties": {
    "type":             { "const": "inbox" },
    "title":            { "type": "string", "minLength": 1 },
    "created":          { "type": "string", "format": "date" },
    "updated":          { "type": "string", "format": "date" },
    "status":           { "enum": ["raw", "triaged", "promoted", "dropped"] },
    "tags":             { "type": "array", "items": { "type": "string" } },
    "suggested_type":   { "enum": ["issue", "thread", "design", "learning", "discard"] },
    "suggested_project":{ "type": ["string", "null"] },
    "promoted_to":      { "type": ["string", "null"] },
    "promoted_type":    { "enum": ["issue", "thread", "design", "learning"] },
    "related":          { "type": "array", "items": { "type": "string" } },
    "external_links":   { "type": "array", "items": { "type": "string", "minLength": 1 } }
  },
  "additionalProperties": false
}
