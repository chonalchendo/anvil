{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anvil.dev/schemas/plan.schema.json",
  "title": "plan",
  "type": "object",
  "required": [
    "type", "id", "slug", "title", "created", "updated",
    "status", "plan_version", "milestone", "issue", "tasks"
  ],
  "properties": {
    "type":         { "const": "plan" },
    "id":           { "type": "string", "minLength": 1 },
    "slug":         { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "title":        { "type": "string", "minLength": 1 },
    "created":      { "type": "string", "format": "date" },
    "updated":      { "type": "string", "format": "date" },
    "status":       { "enum": ["draft", "locked", "in-progress", "done", "abandoned"] },
    "plan_version": { "type": "integer", "minimum": 1 },
    "milestone":    { "type": "string", "minLength": 1 },
    "issue":        { "type": "string", "minLength": 1 },
    "authorized_by":{ "type": "array", "items": { "type": "string" } },
    "tags":         { "type": "array", "items": { "type": "string" } },
    "aliases":      { "type": "array", "items": { "type": "string" } },
    "project":      { "type": "string" },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "summary"],
        "properties": {
          "id":      { "type": "string" },
          "summary": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "non_goals":    { "type": "array", "items": { "type": "string" } },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "kind", "files", "depends_on", "verify"],
        "properties": {
          "id":              { "type": "string", "pattern": "^T[0-9]+$" },
          "title":           { "type": "string", "minLength": 1 },
          "kind":            { "enum": ["tdd", "mechanical"] },
          "files":           { "type": "array", "items": { "type": "string" } },
          "depends_on":      { "type": "array", "items": { "type": "string", "pattern": "^T[0-9]+$" } },
          "skills_to_load":  { "type": "array", "items": { "type": "string" } },
          "verify":          { "type": "string", "minLength": 1 },
          "success_criteria":{ "type": "array", "items": { "type": "string" } },
          "budget": {
            "type": "object",
            "properties": {
              "max_lines_changed": { "type": "integer", "minimum": 1 },
              "max_files_touched": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "verification": {
      "type": "object",
      "properties": {
        "pre_build":  { "type": "array", "items": { "type": "string" } },
        "post_build": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "references": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
