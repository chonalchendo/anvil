{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anvil.dev/schemas/plan.schema.json",
  "title": "plan",
  "type": "object",
  "required": ["type", "title", "created", "status", "horizon", "target_date"],
  "properties": {
    "type":         { "const": "plan" },
    "title":        { "type": "string", "minLength": 1 },
    "created":      { "type": "string", "format": "date" },
    "updated":      { "type": "string", "format": "date" },
    "status":       { "enum": ["draft", "active", "paused", "done", "abandoned"] },
    "tags":         { "type": "array", "items": { "type": "string" } },
    "aliases":      { "type": "array", "items": { "type": "string" } },
    "horizon":      { "enum": ["week", "sprint", "month", "quarter", "year", "open"] },
    "target_date":  { "type": "string", "format": "date" },
    "project":      { "type": "string" },
    "owner":        { "type": ["string", "null"] },
    "stakeholders": { "type": "array", "items": { "type": "string" } },
    "authorized_by":{ "type": "array", "items": { "type": "string" } },
    "objectives":   { "type": "array", "items": { "type": "string" } },
    "milestones":   { "type": "array", "items": { "type": "string" } },
    "sweeps":       { "type": "array", "items": { "type": "string" } },
    "risks":        { "type": "array", "items": { "type": "string" } },
    "children":     { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
