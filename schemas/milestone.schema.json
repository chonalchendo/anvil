{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anvil.dev/schemas/milestone.schema.json",
  "title": "milestone",
  "type": "object",
  "required": ["type", "title", "description", "created", "status", "project"],
  "properties": {
    "type":           { "const": "milestone" },
    "title":          { "type": "string", "minLength": 1 },
    "description":    { "type": "string", "minLength": 1, "maxLength": 120, "pattern": "^[^\\n]+$" },
    "created":        { "type": "string", "format": "date" },
    "updated":        { "type": "string", "format": "date" },
    "status":         { "enum": ["planned", "in-progress", "done", "abandoned"] },
    "tags":           { "type": "array", "items": { "type": "string" } },
    "aliases":        { "type": "array", "items": { "type": "string" } },
    "project":        { "type": "string", "minLength": 1 },
    "product_design": { "type": "string", "minLength": 1 },
    "system_design":  { "type": "string", "minLength": 1 },
    "authorized_by":  { "type": "array", "items": { "type": "string" } },
    "acceptance":     { "type": "array", "items": { "type": "string" } },
    "related":        { "type": "array", "items": { "type": "string" } },
    "external_links": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
