{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anvil.dev/schemas/milestone.schema.json",
  "title": "milestone",
  "type": "object",
  "required": ["type", "title", "created", "status", "target_date"],
  "properties": {
    "type":           { "const": "milestone" },
    "title":          { "type": "string", "minLength": 1 },
    "created":        { "type": "string", "format": "date" },
    "updated":        { "type": "string", "format": "date" },
    "status":         { "enum": ["planned", "in-progress", "done", "abandoned"] },
    "tags":           { "type": "array", "items": { "type": "string" } },
    "aliases":        { "type": "array", "items": { "type": "string" } },
    "target_date":    { "type": "string", "format": "date" },
    "horizon":        { "enum": ["week", "sprint", "month", "quarter", "year", "open"] },
    "project":        { "type": "string" },
    "product_design": { "type": ["string", "null"] },
    "authorized_by":  { "type": "array", "items": { "type": "string" } },
    "predecessors":   { "type": "array", "items": { "type": "string" } },
    "successors":     { "type": "array", "items": { "type": "string" } },
    "plans":          { "type": "array", "items": { "type": "string" } },
    "issues":         { "type": "array", "items": { "type": "string" } },
    "acceptance":     { "type": "array", "items": { "type": "string" } },
    "risks":          { "type": "array", "items": { "type": "string" } },
    "related":        { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
