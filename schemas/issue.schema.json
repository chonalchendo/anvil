{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anvil.dev/schemas/issue.schema.json",
  "title": "issue",
  "type": "object",
  "required": ["type", "title", "created", "status", "project", "severity"],
  "properties": {
    "type":         { "const": "issue" },
    "title":        { "type": "string", "minLength": 1 },
    "created":      { "type": "string", "format": "date" },
    "updated":      { "type": "string", "format": "date" },
    "status":       { "enum": ["open", "in-progress", "resolved", "abandoned"] },
    "tags":         { "type": "array", "items": { "type": "string" } },
    "aliases":      { "type": "array", "items": { "type": "string" } },
    "project":      { "type": "string", "minLength": 1 },
    "severity":     { "enum": ["low", "medium", "high", "critical"] },
    "milestone":    { "type": "string", "minLength": 1 },
    "external_ref": { "type": ["string", "null"] },
    "external_url": { "type": ["string", "null"] },
    "acceptance":   { "type": "array", "items": { "type": "string" } },
    "related":      { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
