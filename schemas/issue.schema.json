{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anvil.dev/schemas/issue.schema.json",
  "title": "issue",
  "type": "object",
  "required": ["type", "title", "description", "created", "status", "project", "severity", "tags"],
  "properties": {
    "type":         { "const": "issue" },
    "title":        { "type": "string", "minLength": 1 },
    "description":  { "type": "string", "minLength": 1, "maxLength": 120, "pattern": "^[^\\n]+$" },
    "created":      { "type": "string", "format": "date" },
    "updated":      { "type": "string", "format": "date" },
    "status":       { "enum": ["open", "in-progress", "resolved", "abandoned"] },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "allOf": [
        { "contains": { "type": "string", "pattern": "^domain/[a-z0-9-]+$" }, "minContains": 1 }
      ]
    },
    "aliases":      { "type": "array", "items": { "type": "string" } },
    "project":      { "type": "string", "minLength": 1 },
    "severity":     { "enum": ["low", "medium", "high", "critical"] },
    "milestone":    { "type": "string", "minLength": 1 },
    "owner":        { "type": "string", "minLength": 1 },
    "acceptance":   { "type": "array", "items": { "type": "string" } },
    "related":      { "type": "array", "items": { "type": "string" } },
    "external_links": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "blocks":       { "type": "array", "items": { "type": "string" } },
    "depends_on":   { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
